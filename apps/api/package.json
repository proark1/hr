{
  "name": "@myhr/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "predev": "pnpm --filter \"@myhr/api^...\" build",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit",
    "lint": "tsc --noEmit"
  },
  "dependencies": {
    "@fastify/sensible": "6.0.2",
    "@myhr/db": "workspace:*",
    "@myhr/types": "workspace:*",
    "better-auth": "1.1.21",
    "fastify": "5.1.0",
    "fastify-plugin": "5.0.1",
    "fastify-type-provider-zod": "4.0.2",
    "pino-pretty": "13.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@types/node": "22.9.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
