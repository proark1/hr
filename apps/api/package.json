{
  "name": "@myhr/api",
  "version": "0.0.1",
  "private": true,
  "type": "module",
  "main": "dist/index.js",
  "scripts": {
    "predev": "pnpm --filter \"@myhr/api^...\" build",
    "dev": "tsx watch src/index.ts",
    "build": "tsc",
    "start": "node dist/index.js",
    "typecheck": "tsc --noEmit && tsc --noEmit -p scripts/tsconfig.json",
    "lint": "tsc --noEmit",
    "openapi:dump": "tsx scripts/dump-openapi.ts",
    "openapi:check": "tsx scripts/dump-openapi.ts && git diff --exit-code -- openapi.json",
    "openapi:lint": "redocly lint openapi.json",
    "openapi:docs": "redocly build-docs openapi.json --output dist-docs/index.html",
    "openapi:sdk-coverage": "tsx scripts/check-sdk-coverage.ts"
  },
  "dependencies": {
    "@fastify/sensible": "6.0.2",
    "@fastify/swagger": "^9.7.0",
    "@fastify/swagger-ui": "^5.2.6",
    "@myhr/db": "workspace:*",
    "@myhr/types": "workspace:*",
    "fastify": "5.1.0",
    "jose": "5.9.6",
    "fastify-plugin": "5.0.1",
    "fastify-type-provider-zod": "4.0.2",
    "pg-boss": "10.1.5",
    "pino-pretty": "13.0.0",
    "zod": "3.25.76"
  },
  "devDependencies": {
    "@myhr/sdk": "workspace:*",
    "@redocly/cli": "^1.34.14",
    "@types/node": "22.9.0",
    "tsx": "4.19.2",
    "typescript": "5.6.3"
  }
}
