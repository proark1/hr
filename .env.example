# API
NODE_ENV=development
PORT=8080
LOG_LEVEL=info
# Public base URL of the API. Used as the OpenAPI `servers[0].url` so the
# Swagger UI "Try it out" feature targets the right host. If unset we fall
# back to http://localhost:$PORT.
# PUBLIC_API_URL=https://api.myhr.example

# Postgres (Railway). Use the EU region in production.
# The api role must NOT own tables; RLS is FORCED so even owners are scoped.
DATABASE_URL=postgresql://app:password@localhost:5432/myhr?schema=public
DIRECT_DATABASE_URL=postgresql://migrator:password@localhost:5432/myhr?schema=public

# Master API key for 1tap. Generate with: openssl rand -hex 32
# Stored hashed in DB; this env var is the bootstrap secret used to seed it.
MASTER_API_KEY=mh_live_replace_me

# Encryption key for field-level encryption of sensitive HR data (SSN, IBAN, Steuer-ID).
# 32 bytes, base64. Generate with: openssl rand -base64 32
FIELD_ENCRYPTION_KEY=replace_me_base64_32_bytes

# Webhook signing secret (per-org override possible later)
WEBHOOK_SIGNING_SECRET=replace_me

# Better Auth — required only when end users log into the web dashboard.
# Same value MUST be set on both the API and the Next.js web app.
# Generate with: openssl rand -hex 32
# Leave commented out until you have a value; an empty string fails the
# min(16) validation in apps/api/src/env.ts.
# BETTER_AUTH_SECRET=
# Public origin of the web app. Required when BETTER_AUTH_SECRET is set.
WEB_APP_URL=http://localhost:3000
# Web app reads this for the Better Auth client baseURL. Mirror of WEB_APP_URL.
NEXT_PUBLIC_APP_URL=http://localhost:3000
# Web app -> API base URL (used by server actions and the SDK).
MYHR_API_URL=http://localhost:8080

# Google OAuth (optional — email/password auth works without it).
GOOGLE_CLIENT_ID=
GOOGLE_CLIENT_SECRET=

# Email — proark1/emailservice (mailnowapi.com). If MAILNOW_API_KEY is unset,
# invitation emails are logged to stdout instead of sent.
MAILNOW_API_KEY=
EMAIL_FROM=

# Object storage (Cloudflare R2, EU)
R2_ACCOUNT_ID=
R2_ACCESS_KEY_ID=
R2_SECRET_ACCESS_KEY=
R2_BUCKET=myhr-documents-eu

# Stripe (invoicing)
STRIPE_SECRET_KEY=
STRIPE_WEBHOOK_SECRET=
