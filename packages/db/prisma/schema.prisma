// MyHR database schema.
//
// Multi-tenant: every personal-data table carries org_id and is protected by
// Postgres Row-Level Security. Application connects as a non-owner role; the
// tenant middleware sets `app.current_org_id` (and `app.is_master`) at the
// start of every transaction.
//
// See migrations/<timestamp>_init/migration.sql for the RLS policies.

generator client {
  provider        = "prisma-client-js"
  previewFeatures = ["postgresqlExtensions"]
}

datasource db {
  provider          = "postgresql"
  url               = env("DATABASE_URL")
  directUrl         = env("DIRECT_DATABASE_URL")
  extensions        = [pgcrypto, citext]
}

// -- Tenants -----------------------------------------------------------------

enum OrgRegion {
  eu
  us
}

enum OrgStatus {
  active
  suspended
  deleted
}

enum BillingMode {
  invoice
  subscription
  partner
}

model Org {
  id                   String      @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  name                 String
  region               OrgRegion   @default(eu)
  status               OrgStatus   @default(active)
  // Reserved for the Stripe self-serve PR. 1tap-provisioned orgs get
  // billing_mode='partner' (no per-seat metering); UI signups default to
  // 'subscription'. 'invoice' is for old-school manual invoicing.
  billingMode          BillingMode @default(subscription) @map("billing_mode")
  stripeCustomerId     String?     @map("stripe_customer_id")
  stripeSubscriptionId String?     @map("stripe_subscription_id")
  plan                 String?
  createdAt            DateTime    @default(now()) @map("created_at")
  updatedAt            DateTime    @updatedAt @map("updated_at")
  deletedAt            DateTime?   @map("deleted_at")

  employees   Employee[]
  apiKeys     ApiKey[]
  auditEvents AuditEvent[]
  webhooks    WebhookEndpoint[]
  memberships OrgMembership[]
  invitations Invitation[]

  @@map("orgs")
}

// -- Auth (master + tenant-scoped keys; v1 ships master only) ----------------

enum ApiKeyScope {
  master
  tenant
}

model ApiKey {
  id          String       @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  scope       ApiKeyScope
  orgId       String?      @map("org_id") @db.Uuid
  name        String
  prefix      String       @unique // e.g. "mh_live_abcd" (first 12 chars, for display + lookup)
  hash        String       // sha256(secret), hex
  lastUsedAt  DateTime?    @map("last_used_at")
  createdAt   DateTime     @default(now()) @map("created_at")
  revokedAt   DateTime?    @map("revoked_at")

  org Org? @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("api_keys")
}

// -- Employees ---------------------------------------------------------------

enum EmployeeStatus {
  onboarding
  active
  on_leave
  terminated
}

enum EmployeeCountry {
  us
  de
}

model Employee {
  id            String          @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId         String          @map("org_id") @db.Uuid
  externalId    String?         @map("external_id") // 1tap's stable ID for this person
  email         String          @db.Citext
  firstName     String          @map("first_name")
  lastName      String          @map("last_name")
  preferredName String?         @map("preferred_name")
  jobTitle      String?         @map("job_title")
  department    String?
  managerId     String?         @map("manager_id") @db.Uuid
  country       EmployeeCountry
  startDate     DateTime        @map("start_date") @db.Date
  endDate       DateTime?       @map("end_date") @db.Date
  status        EmployeeStatus  @default(onboarding)
  // Encrypted blob (libsodium sealed box) for tax IDs, IBAN etc. Schema-less by design.
  sensitive     Bytes?
  createdAt     DateTime        @default(now()) @map("created_at")
  updatedAt     DateTime        @updatedAt @map("updated_at")
  deletedAt     DateTime?       @map("deleted_at")

  org      Org        @relation(fields: [orgId], references: [id])
  // Composite FK (managerId, orgId) → (id, orgId). Enforced at the DB level
  // so a manager cannot reference an employee from a different tenant — FK
  // checks bypass RLS, so the orgId in the FK is the only place this is
  // enforced at the storage layer.
  manager  Employee?  @relation("EmployeeManager", fields: [managerId, orgId], references: [id, orgId])
  reports  Employee[] @relation("EmployeeManager")

  @@unique([id, orgId])
  @@unique([orgId, email])
  @@unique([orgId, externalId])
  @@index([orgId, status])
  @@index([orgId, managerId])
  @@map("employees")
}

// -- Audit log ---------------------------------------------------------------

model AuditEvent {
  id         BigInt   @id @default(autoincrement())
  orgId      String?  @map("org_id") @db.Uuid
  actorType  String   @map("actor_type") // "master" | "tenant" | "system"
  actorId    String?  @map("actor_id")   // 1tap user id from X-Actor header
  actorEmail String?  @map("actor_email")
  action     String   // "employee.created", "employee.read", ...
  resource   String?  // "employee:<uuid>"
  ip         String?
  userAgent  String?  @map("user_agent")
  metadata   Json?
  createdAt  DateTime @default(now()) @map("created_at")

  org Org? @relation(fields: [orgId], references: [id])

  @@index([orgId, createdAt])
  @@index([action, createdAt])
  @@map("audit_events")
}

// -- Idempotency -------------------------------------------------------------

model IdempotencyKey {
  key          String   @id
  orgId        String?  @map("org_id") @db.Uuid
  method       String
  path         String
  requestHash  String   @map("request_hash")
  statusCode   Int      @map("status_code")
  responseBody Json     @map("response_body")
  createdAt    DateTime @default(now()) @map("created_at")
  expiresAt    DateTime @map("expires_at")

  @@index([expiresAt])
  @@map("idempotency_keys")
}

// -- Webhooks (registration only; delivery wired in a later PR) --------------

model WebhookEndpoint {
  id         String   @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId      String?  @map("org_id") @db.Uuid // null = master-level (cross-tenant)
  url        String
  events     String[] // e.g. ["employee.created", "leave.approved"]
  secret     String   // hmac signing secret for this endpoint
  disabledAt DateTime? @map("disabled_at")
  createdAt  DateTime @default(now()) @map("created_at")

  org Org? @relation(fields: [orgId], references: [id])

  @@index([orgId])
  @@map("webhook_endpoints")
}

// -- Better Auth -------------------------------------------------------------
//
// User / Session / Account / Verification are owned and managed by Better
// Auth's prisma adapter. The Prisma model names are the names Better Auth
// expects; @@map keeps the SQL plural-snake-case to match our convention.
// These tables are NOT under RLS — Better Auth queries them directly without
// our session vars, and they only contain auth-system data (no HR PII).

model User {
  id            String   @id // Better Auth assigns text ids
  name          String?
  email         String   @unique @db.Citext
  emailVerified Boolean  @default(false) @map("email_verified")
  image         String?
  isSuperAdmin  Boolean  @default(false) @map("is_super_admin")
  createdAt     DateTime @default(now()) @map("created_at")
  updatedAt     DateTime @updatedAt @map("updated_at")

  sessions    Session[]
  accounts    Account[]
  memberships OrgMembership[]
  invitations Invitation[]   @relation("InvitedBy")

  @@map("users")
}

model Session {
  id        String   @id
  expiresAt DateTime @map("expires_at")
  token     String   @unique
  userId    String   @map("user_id")
  ipAddress String?  @map("ip_address")
  userAgent String?  @map("user_agent")
  createdAt DateTime @default(now()) @map("created_at")
  updatedAt DateTime @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@index([userId])
  @@index([expiresAt])
  @@map("sessions")
}

model Account {
  id                    String    @id
  accountId             String    @map("account_id")   // provider's user id
  providerId            String    @map("provider_id")  // "credential" | "google" | ...
  userId                String    @map("user_id")
  accessToken           String?   @map("access_token")
  refreshToken          String?   @map("refresh_token")
  idToken               String?   @map("id_token")
  accessTokenExpiresAt  DateTime? @map("access_token_expires_at")
  refreshTokenExpiresAt DateTime? @map("refresh_token_expires_at")
  scope                 String?
  password              String?   // bcrypt hash for email/password provider
  createdAt             DateTime  @default(now()) @map("created_at")
  updatedAt             DateTime  @updatedAt @map("updated_at")

  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([providerId, accountId])
  @@index([userId])
  @@map("accounts")
}

model Verification {
  id         String   @id
  identifier String   // email being verified, or password reset key, ...
  value      String
  expiresAt  DateTime @map("expires_at")
  createdAt  DateTime @default(now()) @map("created_at")
  updatedAt  DateTime @updatedAt @map("updated_at")

  @@index([identifier])
  @@index([expiresAt])
  @@map("verifications")
}

// -- Memberships + invitations ----------------------------------------------

enum MembershipRole {
  owner
  admin
  manager
  member
}

model OrgMembership {
  id        String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId     String         @map("org_id") @db.Uuid
  userId    String         @map("user_id")
  role      MembershipRole
  createdAt DateTime       @default(now()) @map("created_at")
  updatedAt DateTime       @updatedAt @map("updated_at")
  deletedAt DateTime?      @map("deleted_at")

  org  Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  user User @relation(fields: [userId], references: [id], onDelete: Cascade)

  @@unique([orgId, userId])
  @@index([userId])
  @@index([orgId, role])
  @@map("org_memberships")
}

model Invitation {
  id              String         @id @default(dbgenerated("gen_random_uuid()")) @db.Uuid
  orgId           String         @map("org_id") @db.Uuid
  email           String         @db.Citext
  role            MembershipRole
  tokenHash       String         @map("token_hash")
  invitedByUserId String         @map("invited_by_user_id")
  expiresAt       DateTime       @map("expires_at")
  acceptedAt      DateTime?      @map("accepted_at")
  revokedAt       DateTime?      @map("revoked_at")
  createdAt       DateTime       @default(now()) @map("created_at")

  org       Org  @relation(fields: [orgId], references: [id], onDelete: Cascade)
  invitedBy User @relation("InvitedBy", fields: [invitedByUserId], references: [id])

  @@index([orgId])
  @@index([email])
  @@map("invitations")
}
