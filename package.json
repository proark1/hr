{
  "name": "myhr",
  "private": true,
  "version": "0.0.1",
  "description": "OurTeamManagement — API-first multi-tenant HR service",
  "packageManager": "pnpm@10.33.2",
  "engines": {
    "node": ">=22"
  },
  "scripts": {
    "build": "pnpm -r build",
    "typecheck": "pnpm -r typecheck",
    "lint": "pnpm -r lint",
    "db:generate": "pnpm --filter @myhr/db generate",
    "db:migrate": "pnpm --filter @myhr/db migrate",
    "db:migrate:deploy": "pnpm --filter @myhr/db migrate:deploy",
    "api:dev": "pnpm --filter @myhr/api dev",
    "web:dev": "pnpm --filter @myhr/web dev",
    "mcp:dev": "pnpm --filter @myhr/mcp dev"
  },
  "devDependencies": {
    "typescript": "5.6.3"
  }
}
